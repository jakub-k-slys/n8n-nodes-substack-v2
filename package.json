{
  "name": "n8n-nodes-substack-v2",
  "version": "0.0.1",
  "description": "n8n community node for Substack API integration",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "",
  "author": {
    "name": "Jakub Slys",
    "email": "jakub@slys.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jakub-k-slys/n8n-nodes-substack-v2.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "pnpm run build && eslint -c eslint.prepublish.config.js nodes credentials package.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SubstackGatewayApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SubstackGateway/Substack.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/parser": "~8.57.2",
    "eslint": ">=9.29.0 <10",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "jest": "^30.0.3",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.82.0"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "axios-rate-limit": "^1.4.0",
    "fp-ts": "^2.16.10",
    "io-ts": "^2.2.22"
  }
}
